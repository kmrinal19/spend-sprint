{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"moduleResolution": "bundler",
		"target": "ES2022",
		"module": "ES2022",
		"verbatimModuleSyntax": true,
		"skipLibCheck": true
	}
}
